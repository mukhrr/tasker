# ── required: Supabase (same project as the sniper/extension) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_USER_ID=00000000-0000-0000-0000-000000000000

# ── required: Codex auth (ChatGPT plan) ──
# Run `codex login` on a machine with a browser, then paste the FULL contents of
# ~/.codex/auth.json here. It is written to CODEX_HOME/auth.json on first boot and
# refreshed in place afterward — CODEX_HOME MUST live on a persistent volume.
CODEX_AUTH_JSON=
# CODEX_MODEL=            # optional: pin a model (e.g. gpt-5-codex); '' = account default
# CODEX_UNSAFE_SANDBOX=false  # set true only if Landlock/seccomp fails in the container

# ── GitHub (reads issues/comments; posts on the direct-post fast path) ──
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── behavior ──
# true = draft + validate but never arm/post/mutate Supabase (logs only). Flip to
# false to go live. Start with DRY_RUN=true and read the logged proposals first.
DRY_RUN=true
# Run the deeper enrichment pass (stronger RCA, git history, permalinks, diffs)
# after arming. Turn on once draft quality is trusted.
ENRICH=false
# Post immediately if the issue already carries Help Wanted (the sniper ignores
# stale HW events, so the drafter posts these directly).
DIRECT_POST=true

# ── repo + data (persistent volume) ──
REPO=Expensify/App
DATA_DIR=/data
# CODEX_HOME=/data/codex   # defaults under DATA_DIR
# REPO_DIR=/data/App       # defaults under DATA_DIR

# ── timing (sane defaults) ──
POLL_INTERVAL_MS=3000
CODEX_TIMEOUT_MS=600000
STALE_DRAFTING_MS=1800000
MAX_DRAFT_ATTEMPTS=3

# ── optional: Telegram (drafting/arm/post/enrich pings) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

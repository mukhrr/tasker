# Tasker analyzer — runs on YOUR MAC (needs Claude Code subscription auth + the
# local Expensify/App checkout). Copy to .env and fill in, then:
#   node --env-file=.env analyzer.mjs

# Same values the Railway workers use (Supabase project settings → API).
SUPABASE_URL=https://tnidhlefxtqzkeyukcbv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USER_ID=

# Local Expensify/App checkout (your fork is fine).
APP_REPO_DIR=/Users/mukhriddin/Documents/App

# Classic PAT with public_repo — used to read issues and edit your posted
# proposal comment. Without it, comment updates are skipped.
GITHUB_TOKEN=

# Optional Telegram ping when an analysis finishes.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Claude Code (uses your logged-in subscription; no API key involved).
# CLAUDE_BIN=claude
# CLAUDE_MODEL=            # empty → CLI default
# CLAUDE_TIMEOUT_MS=2700000

# Optional: throwaway STAGING test account for live web repro sign-in (never a
# real/personal account). Use a fixed-magic-code account so headless login works.
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_MAGIC_CODE=

# ── required ──
# Classic GitHub Personal Access Token with the `public_repo` scope.
# (Fine-grained PATs can't write to repos you don't own, so use a classic one.)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── extension integration (recommended for Railway) ──
# When all three are set, the worker continuously loads proposal bodies that
# this user armed in the extension. Find these values in the Supabase dashboard.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_USER_ID=00000000-0000-0000-0000-000000000000
# How quickly a newly armed proposal becomes watched. This is not the tight
# GitHub label-poll interval; proposals are normally armed well in advance.
ARMED_SYNC_INTERVAL_MS=1000

# ── what to race ──
# Repo to watch (owner/name).
REPO=Expensify/App
# Comma-separated issue numbers to race (stage a body in proposals/<n>.md).
WATCH=
# Set true to watch the WHOLE repo (lock on External, fire on Help Wanted).
# ⚠️ Be selective — blanket auto-posting to every issue is a ban risk.
# Keep this false with extension integration; armed proposals are watched automatically.
DISCOVER=false

# ── safety ──
# true = log what it WOULD post, never actually post. Flip to false to go live.
DRY_RUN=true

# ── timing (defaults are sane; tune only if you hit secondary rate limits) ──
DISCOVERY_INTERVAL_MS=900
TIGHT_INTERVAL_MS=50
TIGHT_WINDOW_MS=15000
FRESH_LOCK_MS=20000
FIRE_FRESH_MS=8000
# GitHub truncates created_at to whole seconds; a comment created in the SAME
# second as Help Wanted can render ABOVE the label. The worker waits just past
# the next second boundary (tracked from response Date headers) plus this margin.
POST_BOUNDARY_MARGIN_MS=150
# Hard cap on GitHub requests per minute, 304s included — well under GitHub's
# ~900 points/min secondary limit. Polling degrades gracefully at the cap
# (discovery yields first at 80%); the comment POST itself is never gated.
REQUEST_BUDGET_PER_MIN=500
# Poll cadence while over budget.
THROTTLED_INTERVAL_MS=250
# Delay before the post-snipe race report (timeline position vs rivals). 0 disables.
POST_MORTEM_DELAY_MS=10000

# ── labels (defaults match Expensify's pipeline) ──
LABEL_LOCK=External
LABEL_TRIGGER=Help Wanted

# ── optional: Telegram ping the moment a snipe fires ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── optional: default proposal body file (per-issue files override this) ──
# PROPOSAL_FILE=./proposal.md
# PROPOSAL_DIR=./proposals

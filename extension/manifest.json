{
  "manifest_version": 3,
  "name": "Tasker for GitHub",
  "version": "1.7.9",
  "description": "View and update Tasker task statuses directly on GitHub issues and PRs.",
  "permissions": ["storage", "identity", "alarms", "notifications"],
  "host_permissions": [
    "https://github.com/*",
    "https://*.supabase.co/*",
    "https://api.telegram.org/*",
    "https://api.github.com/*",
    "https://taskerr.it.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
